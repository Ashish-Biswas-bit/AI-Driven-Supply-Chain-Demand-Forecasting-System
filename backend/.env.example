# Database Configuration
# For SQLite (local development): DATABASE_URL=sqlite:///./supply_chain.db
# For Supabase PostgreSQL: DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=sqlite:///./supply_chain.db

# Supabase Configuration (required when using Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI API (for AI features)
OPENAI_API_KEY=your-openai-api-key
